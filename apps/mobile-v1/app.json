{
  "expo": {
    "name": "levels+lines Mobile",
    "slug": "levellines-mobile-v1",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "jsEngine": "hermes",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0B"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.uk.levellines.mobile"
    },
    "android": {
      "package": "co.uk.levellines.mobile"
    },
    "extra": {
      "apiBaseUrl": "https://levellines.co.uk/api/v2"
    }
  }
}
