{
  "expo": {
    "name": "Level Lines Client",
    "slug": "levellines-mobile-client",
    "scheme": "levellines-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "jsEngine": "hermes",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0B"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.uk.levellines.client"
    },
    "android": {
      "package": "co.uk.levellines.client"
    },
    "extra": {
      "appVariant": "client",
      "apiEnvironment": "production",
      "apiBaseUrls": {
        "local": "http://10.0.2.2:3000/api/v2",
        "staging": "https://staging.levellines.co.uk/api/v2",
        "production": "https://levellines.co.uk/api/v2"
      }
    }
  }
}
