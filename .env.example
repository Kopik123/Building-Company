PORT=3000
NODE_ENV=production
APP_URL=https://your-domain.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/building_company
# or for MySQL: mysql://user:password@localhost:3306/building_company

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# SMTP (DigitalOcean + your mail provider, e.g. Mailgun/Brevo/SMTP server)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# Where contact form emails are sent
CONTACT_TO=info@example.com

# Optional. If empty, SMTP_USER will be used.
CONTACT_FROM=no-reply@example.com
