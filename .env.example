PORT=3000
NODE_ENV=production
APP_URL=https://your-domain.com

# Database (PostgreSQL on the same Droplet)
DATABASE_URL=postgresql://buildingco:CHANGE_ME@localhost:5432/building_company

# JWT Secret – generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# Bootstrap key used to create the first admin/manager account
# Generate with: openssl rand -hex 24
BOOTSTRAP_ADMIN_KEY=CHANGE_ME_use_openssl_rand_hex_24

# Allowed CORS origins (comma-separated). Leave empty to allow all.
# Example: https://your-domain.com,https://www.your-domain.com
CORS_ORIGINS=

# Public HTTP cache TTLs (milliseconds)
PUBLIC_SERVICES_CACHE_TTL_MS=30000
PUBLIC_GALLERY_CACHE_TTL_MS=30000

# SMTP
# Option A (recommended on DigitalOcean): local Postfix relay on the same Droplet
#   SMTP_HOST=127.0.0.1
#   SMTP_PORT=25
#   SMTP_SECURE=false
#   SMTP_USER=
#   SMTP_PASS=
# Option B: external SMTP provider (Mailgun/Brevo/etc.)
SMTP_HOST=127.0.0.1
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Where contact form emails are sent
CONTACT_TO=info@example.com

# Optional. If empty, SMTP_USER will be used as the from address.
CONTACT_FROM=no-reply@example.com

# Optional: SMS webhook URL for phone-based quote claim codes
# CLAIM_SMS_WEBHOOK_URL=https://hooks.example.com/sms

