PORT=3000

# SMTP (DigitalOcean + your mail provider, e.g. Mailgun/Brevo/SMTP server)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# Where contact form emails are sent
CONTACT_TO=info@example.com

# Optional. If empty, SMTP_USER will be used.
CONTACT_FROM=no-reply@example.com
